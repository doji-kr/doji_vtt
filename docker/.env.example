# docker/.env로 복사해서 값을 채운 뒤 `docker compose up -d`를 실행한다.
# SESSION_SECRET은 반드시 고정값으로 채워야 한다 — 비워두면 서버가 매번 임의의 키를
# 생성해서, 컨테이너를 재시작할 때마다 기존 로그인 쿠키가 전부 무효화된다.
SESSION_SECRET=여기에_긴_무작위_문자열을_붙여넣는다

# 비워두면 초대코드 검사를 하지 않는다(개발용). 운영에서는 반드시 채운다.
INVITE_CODE=여기에_초대코드

# 4단계 §4: WebRTC 음성. 세 값 다 비워두면 coturn 컨테이너와 TURN 자격증명 발급을 건너뛰고
# STUN만으로 음성을 시도한다 — 가정용 라우터 대부분은 이걸로 충분하다. NAT 통과가 안 되는
# 환경(대칭형 NAT 등)에서만 coturn이 필요하다.
# TURN_SECRET: coturn의 --static-auth-secret과 반드시 같은 값이어야 한다.
TURN_SECRET=
# TURN_URLS: 클라이언트가 실제로 접속할 주소 — NAS의 공인 IP나 DDNS 도메인이어야 한다
# (docker 내부 호스트명이 아니다). 예: turn:mynas.example.ddns.net:3478
TURN_URLS=
TURN_REALM=hearthside.local
