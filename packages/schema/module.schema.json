{
  "$ref": "#/definitions/Module",
  "definitions": {
    "Module": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "0.1"
        },
        "meta": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string",
              "minLength": 1
            },
            "logline": {
              "type": "string",
              "minLength": 1
            },
            "poster": {
              "type": "string"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "difficulty": {
              "type": "string",
              "enum": [
                "easy",
                "normal",
                "hard"
              ]
            },
            "estimated_minutes": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "start_scene": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "title",
            "logline",
            "start_scene"
          ],
          "additionalProperties": false
        },
        "npcs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "portrait": {
                "type": "string"
              },
              "wants": {
                "type": "string",
                "minLength": 1
              },
              "fears": {
                "type": "string",
                "minLength": 1
              },
              "secret": {
                "type": "string",
                "minLength": 1
              },
              "voice_notes": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "name",
              "wants",
              "fears",
              "secret"
            ],
            "additionalProperties": false
          }
        },
        "flags": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "description": {
                "type": "string"
              }
            },
            "required": [
              "id"
            ],
            "additionalProperties": false
          }
        },
        "scenes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string"
              },
              "read_aloud": {
                "type": "string",
                "minLength": 1
              },
              "dm_notes": {
                "type": "string"
              },
              "secrets": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "dm_notes": {
                      "type": "string",
                      "minLength": 1
                    },
                    "reveal_text": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "dm_notes"
                  ],
                  "additionalProperties": false
                }
              },
              "blocks": {
                "type": "array",
                "items": {
                  "anyOf": [
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "check"
                        },
                        "id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "skill": {
                          "type": "string",
                          "minLength": 1
                        },
                        "dc": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 30
                        },
                        "on_success": {
                          "type": "object",
                          "properties": {
                            "read_aloud": {
                              "type": "string"
                            },
                            "goto": {
                              "type": "string",
                              "minLength": 1
                            },
                            "set_flags": {
                              "type": "object",
                              "additionalProperties": {
                                "type": [
                                  "boolean",
                                  "string",
                                  "number"
                                ]
                              }
                            }
                          },
                          "required": [
                            "goto"
                          ],
                          "additionalProperties": false
                        },
                        "on_fail": {
                          "type": "object",
                          "properties": {
                            "read_aloud": {
                              "type": "string"
                            },
                            "goto": {
                              "type": "string",
                              "minLength": 1
                            },
                            "set_flags": {
                              "$ref": "#/definitions/Module/properties/scenes/items/properties/blocks/items/anyOf/0/properties/on_success/properties/set_flags"
                            }
                          },
                          "required": [
                            "goto"
                          ],
                          "additionalProperties": false
                        }
                      },
                      "required": [
                        "type",
                        "id",
                        "skill",
                        "dc",
                        "on_success",
                        "on_fail"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "choice"
                        },
                        "id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "prompt": {
                          "type": "string"
                        },
                        "options": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "minLength": 1
                              },
                              "label": {
                                "type": "string",
                                "minLength": 1
                              },
                              "goto": {
                                "type": "string",
                                "minLength": 1
                              },
                              "requires_flag": {
                                "type": "string"
                              },
                              "set_flags": {
                                "$ref": "#/definitions/Module/properties/scenes/items/properties/blocks/items/anyOf/0/properties/on_success/properties/set_flags"
                              }
                            },
                            "required": [
                              "id",
                              "label",
                              "goto"
                            ],
                            "additionalProperties": false
                          },
                          "minItems": 1
                        }
                      },
                      "required": [
                        "type",
                        "id",
                        "options"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "encounter"
                        },
                        "id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "name": {
                          "type": "string",
                          "minLength": 1
                        },
                        "read_aloud": {
                          "type": "string"
                        },
                        "dm_notes": {
                          "type": "string"
                        },
                        "monsters": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "goto": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "type",
                        "id",
                        "name"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "handout"
                        },
                        "id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "title": {
                          "type": "string",
                          "minLength": 1
                        },
                        "text": {
                          "type": "string"
                        },
                        "image": {
                          "type": "string"
                        },
                        "goto": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "type",
                        "id",
                        "title"
                      ],
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "properties": {
                        "type": {
                          "type": "string",
                          "const": "secret"
                        },
                        "id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "secret_id": {
                          "type": "string",
                          "minLength": 1
                        },
                        "goto": {
                          "type": "string"
                        },
                        "set_flags": {
                          "$ref": "#/definitions/Module/properties/scenes/items/properties/blocks/items/anyOf/0/properties/on_success/properties/set_flags"
                        }
                      },
                      "required": [
                        "type",
                        "id",
                        "secret_id"
                      ],
                      "additionalProperties": false
                    }
                  ]
                }
              },
              "edges_soft": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "to": {
                      "type": "string",
                      "minLength": 1
                    },
                    "note": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "to"
                  ],
                  "additionalProperties": false
                }
              },
              "ending": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "title": {
                    "type": "string"
                  }
                },
                "required": [
                  "id"
                ],
                "additionalProperties": false
              }
            },
            "required": [
              "id",
              "read_aloud"
            ],
            "additionalProperties": false
          },
          "minItems": 1
        }
      },
      "required": [
        "schema_version",
        "meta",
        "scenes"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
